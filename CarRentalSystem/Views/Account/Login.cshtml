<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">Sisteme Giriş</h4>
                </div>
                <div class="card-body p-4">
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @Html.ValidationSummary(false, "", new { @class = "text-danger list-unstyled mb-0" })
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label">E-posta Adresi</label>
                            <input type="email" name="UserEmail" class="form-control" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Şifre</label>
                            <input type="password" name="UserPassword" class="form-control" required />
                        </div>

                        <button type="submit" class="btn btn-success w-100">Giriş Yap</button>
                    </form>

                    <div class="text-center mt-3">
                        <a href="/Account/Register" class="text-decoration-none">Hesabınız yok mu? Yeni kayıt oluşturun.</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>