@model List<CarRentalSystem.Models.Car>

<div class="container mt-4">
    <h2>Sistemdeki Araçlarımız</h2>
    <hr />

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Plaka</th>
                <th>Marka</th>
                <th>Model</th>
                <th>Günlük Fiyat</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var arac in Model)
            {
                <tr>
                    <td>@arac.CarPlate</td>
                    <td>@arac.CarBrand</td>
                    <td>@arac.CarModel</td>
                    <td>@arac.CarDailyPrice ₺</td>
                </tr>
            }
        </tbody>
    </table>
</div>