@model List<CarRentalSystem.Models.Car>

<div class="container mt-4">
    <h2>Araç Listesi</h2>
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Plaka</th>
                <th>Marka / Model</th>
                <th>Fiyat</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CarPlate</td>
                    <td>@item.CarBrand @item.CarModel</td>
                    <td>@item.CarDailyPrice ₺</td>
                    <td>
                        <a href="/Admin/Car/Edit/@item.CarId" class="btn btn-warning btn-sm">Düzenle</a>
                        <a href="/Admin/Car/Delete/@item.CarId" class="btn btn-danger btn-sm" onclick="return confirm('Bu aracı silmek istediğinize emin misiniz?');">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>